# data/ is regenerable and contains personal usage data (project paths, costs,
# raw API captures). Ignore all of it except the manifest, which is tracked so
# each monthly sync leaves a `git log` audit trail of what was produced.
data/*
!data/manifest.json

# config/ is tracked (pricing table, auth template) EXCEPT real credentials.
config/*.auth.sh

# OS / editor cruft
.DS_Store
*.swp
.idea/
.vscode/
